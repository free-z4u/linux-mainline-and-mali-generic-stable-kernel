@@ -0,0 +1,106 @@
+# SPDX-License-Identifier: (GPL-2.0-only OR BSD-2-Clause)
+%YAML 1.2
+---
+$id: http://devicetree.org/schemas/sound/samsung,nexus10-manta-audio.yaml#
+$schema: http://devicetree.org/meta-schemas/core.yaml#
+
+title: Samsung Manta (Nexus 10) audio complex
+
+maintainers:
+  - Alexandre Marquet <tb@a-marquet.fr>
+
+allOf:
+  - $ref: sound-card-common.yaml#
+
+properties:
+  compatible:
+    const: samsung,nexus10-manta-audio
+
+  samsung,aux-devs:
+    description: Phandle pointing to the es305 voice processor.
+    $ref: /schemas/types.yaml#/definitions/phandle-array
+
+  samsung,audio-widgets:
+    description: Audio sound widgets.
+    $ref: /schemas/types.yaml#/definitions/non-unique-string-array
+
+  samsung,pin-switches:
+    description: The widget names for which pin switches must be created.
+    $ref: /schemas/types.yaml#/definitions/string-array
+
+  cpu:
+    type: object
+    additionalProperties: false
+    properties:
+      sound-dai:
+        maxItems: 1
+        description: Phandle to the I2S controller.
+    required:
+      - sound-dai
+
+  codec:
+    additionalProperties: false
+    type: object
+    properties:
+      sound-dai:
+        maxItems: 1
+        description: phandle to the WM1811 codec.
+    required:
+      - sound-dai
+
+required:
+  - compatible
+  - samsung,aux-devs
+  - samsung,audio-widgets
+  - samsung,pin-switches
+  - cpu
+  - codec
+
+unevaluatedProperties: false
+
+examples:
+  - |
+    #include <dt-bindings/gpio/gpio.h>
+
+    sound {
+        compatible = "samsung,nexus10-manta-audio";
+
+        model = "Manta WM1811";
+        samsung,aux-devs = <&es305>;
+        audio-routing = 
+            "HP", "HPOUT1L",
+            "HP", "HPOUT1R",
+            "SPK", "SPKOUTLN",
+            "SPK", "SPKOUTLP",
+            "SPK", "SPKOUTRN",
+            "SPK", "SPKOUTRP",
+            "3rd Mic", "MICBIAS1",
+            "IN1LP", "3rd Mic",
+            "IN1LN", "3rd Mic",
+            "Headset Mic", "MICBIAS2",
+            "IN1RP", "Headset Mic",
+            "IN1RN", "Headset Mic",
+            "2nd Mic", "MICBIAS2",
+            "IN2LP:VXRN", "2nd Mic",
+            "Main Mic", "MICBIAS2",
+            "IN2RP:VXRP", "Main Mic",
+            "AIF1DAC1L", "Port D OUT",
+            "AIF1DAC1R", "Port D OUT",
+            "Port A IN", "Playback Mixer",
+            "Port A IN", "Playback Mixer";
+        samsung,audio-widgets =
+            "Headphone", "HP",
+            "Speaker", "SPK",
+            "Microphone", "Headset Mic",
+            "Microphone", "Main Mic",
+            "Microphone", "2nd Mic",
+            "Microphone", "3rd Mic";
+        samsung,pin-switches = "HP", "SPK";
+
+        cpu {
+            sound-dai = <&i2s0 0>;
+        };
+        codec {
+            sound-dai = <&wm1811 0>;
+        };
+    };
