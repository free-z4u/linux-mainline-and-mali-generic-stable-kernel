diff --git a/arch/arm/boot/dts/samsung/exynos5420-n1awifi.dts b/arch/arm/boot/dts/samsung/exynos5420-n1awifi.dts
new file mode 100644
index 000000000000..dcfaf0300c30
--- /dev/null
+++ b/arch/arm/boot/dts/samsung/exynos5420-n1awifi.dts
@@ -0,0 +1,220 @@
+// SPDX-License-Identifier: GPL-2.0
+/*
+ * Samsung's Exynos5420 Galaxy Note 10.1 (2014) WiFi board device tree source
+ *
+ * Copyright (c) 2012-2013 Samsung Electronics Co., Ltd.
+ *		http://www.samsung.com
+ * Copyright (c) 2022 Henrik Grimler
+ * Copyright (c) 2025 Hendrik Noack
+ */
+
+/dts-v1/;
+#include "exynos5420-galaxy-tab-pro-common.dtsi"
+
+/ {
+	model = "Samsung Galaxy Note Pro 10.1 (2014) WiFi based on Exynos5420";
+	compatible = "samsung,n1awifi", "samsung,exynos5420", \
+			"samsung,exynos5";
+
+	memory@20000000 {
+		device_type = "memory";
+		reg = <0x20000000 0xbfa00000>;
+	};
+
+	stylus_reg: stylus-regulator {
+		compatible = "regulator-fixed";
+		regulator-name = "stylus_reg";
+		pinctrl-names = "default";
+		pinctrl-0 = <&stylus_ldo_en>;
+		gpio = <&gpd1 4 GPIO_ACTIVE_HIGH>;
+		enable-active-high;
+		vin-supply = <&ldo3_reg>;
+	};
+};
+
+&i2c_0 {
+	clock-frequency = <400000>;
+};
+
+&hsi2c_5 {
+	status = "okay";
+
+	#address-cells = <1>;
+	#size-cells = <0>;
+
+	backlight: backlight@2c {
+		compatible = "ti,lp8556";
+		reg = <0x2c>;
+
+		bl-name = "lcd-bl";
+		dev-ctrl = /bits/ 8 <0x01>;
+		init-brt = /bits/ 8 <0x72>;	/* 114 */
+
+		pwms = <&pwm 0 100000 0>;
+		pwm-names = "lp8556";
+		pinctrl-names = "default";
+		pinctrl-0 = <&pwm0_out>;
+
+		enable-supply = <&backlight_reset_supply>;
+
+		/* higher inductor current limit */
+		rom-98h {
+			rom-addr = /bits/ 8 <0x98>;
+			rom-val = /bits/ 8 <0xa1>;
+		};
+
+		/* automatic standby via pwm disabled, 25 mA max LED current */
+		rom-a1h {
+			rom-addr = /bits/ 8 <0xa1>;
+			rom-val = /bits/ 8 <0x5f>;
+		};
+
+		/* 200 ms slope, heavy smoothing, 1-bit PWM input hysteresis */
+		rom-a3h {
+			rom-addr = /bits/ 8 <0xa3>;
+			rom-val = /bits/ 8 <0x5e>;
+		};
+
+		/* disable PWM passthrough, 6 PWM output phases, 9616 Hz PWM frequency */
+		rom-a5h {
+			rom-addr = /bits/ 8 <0xa5>;
+			rom-val = /bits/ 8 <0x04>;
+		};
+
+		/* all reserved */
+		rom-a8h {
+			rom-addr = /bits/ 8 <0xa8>;
+			rom-val = /bits/ 8 <0x00>;
+		};
+
+		/* 24 V max output voltage, jump detection on pwm input disabled */
+		rom-a9h {
+			rom-addr = /bits/ 8 <0xa9>;
+			rom-val = /bits/ 8 <0xa0>;
+		};
+	};
+};
+
+&hsi2c_8 {
+	status = "okay";
+
+	#address-cells = <1>;
+	#size-cells = <0>;
+
+	digitizer@56 {
+		compatible = "wacom,w9007a_lt03";
+		reg = <0x56>;
+		pinctrl-names = "default";
+		pinctrl-0 = <&stylus_pdct &stylus_fwe &stylus_insert &stylus_irq>;
+		interrupt-parent = <&gpd1>;
+		interrupts = <1 IRQ_TYPE_EDGE_RISING>;
+
+		vdd-supply = <&stylus_reg>;
+
+		pdct-gpios = <&gpd1 2 GPIO_ACTIVE_LOW>;
+		flash-mode-gpios = <&gpd1 3 GPIO_ACTIVE_HIGH>;
+		pen-inserted-gpios = <&gpx0 0 GPIO_ACTIVE_LOW>;
+
